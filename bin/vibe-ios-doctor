#!/usr/bin/env python3
"""vibe-ios-doctor — a runnable gate for the AGENTS.md iOS posture.

Point it at your Swift sources:

    vibe-ios-doctor Sources/

It enforces the rules a static check can enforce HONESTLY, in two tiers:

  tier 1 (FAIL, exit 1)   — unambiguous: emoji in code, `@unchecked Sendable`
                            without a stated invariant, formatter alloc in a body.
  tier 2 (WARN; FAIL with --strict) — needs a heuristic: an ungated
                            `TimelineView(.animation)` / `.repeatForever`.

It does NOT pretend to catch everything. The tier-2 rule is a token-PRESENCE
heuristic, not a proof of a gating relationship: it flags a continuous animation
when NO guard token and no Bool/Binding parameter is present in the enclosing
view. So it catches the *naive ungated* form, but a guard token that gates a
different view in the same type will suppress the warning (a possible false
negative). Runtime CPU, off-screen `Canvas` redraws, and the 3-minute idle soak
(AGENTS.md §1) are not statically decidable and remain your gate.

Zero dependencies (stdlib only).
"""
from __future__ import annotations

import argparse
import re
import sys
from pathlib import Path

# Emoji codepoint ranges chosen to EXCLUDE typographic punctuation the posture
# itself uses: em-dash U+2014, section sign U+00A7, arrows U+2190-21FF, curly
# quotes. So scanning the kit's own docs/code yields zero false positives.
_EMOJI_RANGES = [
    (0x1F300, 0x1FAFF),  # pictographs, emoticons, transport, extended-A
    (0x2600, 0x26FF),    # miscellaneous symbols
    (0x2700, 0x27BF),    # dingbats
    (0x1F1E6, 0x1F1FF),  # regional indicators (flags)
    (0xFE00, 0xFE0F),    # variation selectors (emoji presentation)
]
# A few emoji that live outside the ranges above (stars, squares) but are clearly
# not punctuation. Listed explicitly so we don't pull in the arrows next to them.
_EMOJI_SINGLES = frozenset({0x2B50, 0x2B55, 0x2B1B, 0x2B1C, 0x303D, 0x3030})

_GUARD_TOKENS = (
    "scenePhase", "isEnabled", "reduceMotion", "accessibilityReduceMotion",
    "onDisappear", "isAnimating", "isVisible", "isActive", "paused",
)
# Whole-word guard tokens (so `isActiveSubscription` does NOT match `isActive`),
# plus a parameter-gate signal: a view that takes a Bool/Binding is plausibly
# gated by its caller, so we do not flag its animations (avoids false positives
# on idiomatic decomposed/leaf views).
_GUARD_RE = re.compile(r"\b(" + "|".join(_GUARD_TOKENS) + r")\b")
_PARAM_GATE_RE = re.compile(r":\s*Bool\b|Binding\s*<")
# Triggers as regex so multi-line / reformatted calls are not silently missed.
_TRIGGERS = [
    ("TimelineView(.animation)", re.compile(r"TimelineView\s*\(\s*\.animation\b")),
    (".repeatForever(...)", re.compile(r"\.repeatForever\s*\(")),
]


class Finding:
    def __init__(self, path, line, tier, message, section):
        self.path, self.line, self.tier = path, line, tier
        self.message, self.section = message, section

    def format(self) -> str:
        kind = "FAIL" if self.tier == 1 else "WARN"
        return f"{self.path}:{self.line}: [{kind}] {self.message} (AGENTS.md {self.section})"


def _lineno(text: str, idx: int) -> int:
    return text.count("\n", 0, idx) + 1


def _is_emoji(ch: str) -> bool:
    cp = ord(ch)
    return cp in _EMOJI_SINGLES or any(lo <= cp <= hi for lo, hi in _EMOJI_RANGES)


def _blank_noncode(text: str) -> str:
    """Replace the CONTENTS of // comments, /* */ comments, and "..." strings
    with spaces, preserving length and newlines (so offsets/line numbers stay
    valid). Guard/trigger scanning runs on this so a token in a comment or string
    can neither suppress a warning (false negative) nor trigger one."""
    out = list(text)
    i, n, state = 0, len(text), None
    while i < n:
        c = text[i]
        nxt = text[i + 1] if i + 1 < n else ""
        if state is None:
            if c == "/" and nxt == "/":
                state, out[i], out[i + 1] = "line", " ", " "
                i += 2; continue
            if c == "/" and nxt == "*":
                state, out[i], out[i + 1] = "block", " ", " "
                i += 2; continue
            if c == '"':
                state = "str"
            i += 1; continue
        if state == "line":
            if c == "\n":
                state = None
            else:
                out[i] = " "
        elif state == "block":
            if c == "*" and nxt == "/":
                state, out[i], out[i + 1] = None, " ", " "
                i += 2; continue
            if c != "\n":
                out[i] = " "
        elif state == "str":
            if c == "\\":
                i += 2; continue
            if c == '"':
                state = None
            elif c != "\n":
                out[i] = " "
        i += 1
    return "".join(out)


def _match_block(text: str, brace_idx: int) -> int:
    """Index of the `}` that closes the `{` at brace_idx."""
    depth = 0
    for i in range(brace_idx, len(text)):
        if text[i] == "{":
            depth += 1
        elif text[i] == "}":
            depth -= 1
            if depth == 0:
                return i
    return len(text)


def _enclosing_type_body(text: str, idx: int) -> str:
    """Body text of the innermost struct/class/extension/enum containing idx."""
    best = ""
    for kw in ("struct ", "class ", "extension ", "enum "):
        start = 0
        while True:
            k = text.find(kw, start)
            if k == -1 or k > idx:
                break
            brace = text.find("{", k)
            if brace == -1:
                break
            end = _match_block(text, brace)
            if brace < idx < end and (end - brace) < len(best or text) + 1:
                # keep the tightest enclosing block
                if not best or (end - brace) <= len(best):
                    best = text[brace:end]
            start = k + len(kw)
    return best


def lint_text(path: str, text: str) -> list[Finding]:
    findings: list[Finding] = []
    code = _blank_noncode(text)  # comments/strings blanked; offsets preserved

    # tier 1 — emoji anywhere in the raw source (comments included).
    for i, ch in enumerate(text):
        if _is_emoji(ch):
            findings.append(Finding(path, _lineno(text, i), 1,
                                    f"emoji {ch!r} in source", "§6"))

    # tier 1 — @unchecked Sendable without a stated invariant (scan raw text so
    # the // invariant: note in a comment counts; walk back over the full
    # contiguous leading comment block, not a fixed 2-line window).
    pos = 0
    while True:
        k = text.find("@unchecked Sendable", pos)
        if k == -1:
            break
        if not _has_invariant_note(text, k):
            findings.append(Finding(path, _lineno(text, k), 1,
                                    "@unchecked Sendable without an // invariant: note", "§2"))
        pos = k + len("@unchecked Sendable")

    # tier 1 — formatter allocation inside a `var body` (on blanked code, so a
    # formatter named in a comment does not count).
    bpos = 0
    while True:
        b = code.find("var body", bpos)
        if b == -1:
            break
        brace = code.find("{", b)
        if brace == -1:
            break
        end = _match_block(code, brace)
        for formatter in ("DateFormatter(", "NumberFormatter("):
            j = code.find(formatter, brace, end)
            if j != -1:
                findings.append(Finding(path, _lineno(text, j), 1,
                                        f"{formatter}) allocated inside a body", "§3"))
        bpos = end

    # tier 2 — ungated continuous animation. A warning is suppressed when the
    # enclosing type carries a whole-word guard token OR takes a Bool/Binding
    # (parameter-gated). This is a token-PRESENCE heuristic, not a proof of a
    # gating relationship — see the module docstring's limitations.
    for label, pattern in _TRIGGERS:
        for m in pattern.finditer(code):
            scope = _enclosing_type_body(code, m.start()) or code
            if _GUARD_RE.search(scope) or _PARAM_GATE_RE.search(scope):
                continue
            findings.append(Finding(path, _lineno(text, m.start()), 2,
                                    f"ungated {label} — no visibility/active guard "
                                    "in the enclosing view", "§1"))

    return findings


def _has_invariant_note(text: str, k: int) -> bool:
    """True if 'invariant' appears on the same line as index k or anywhere in the
    contiguous block of comment lines immediately above it."""
    line_end = text.find("\n", k)
    line_end = line_end if line_end != -1 else len(text)
    line_start = text.rfind("\n", 0, k) + 1
    if "invariant" in text[line_start:line_end].lower():
        return True
    # walk upward over contiguous comment lines
    cursor = line_start
    while cursor > 0:
        prev_end = cursor - 1
        prev_start = text.rfind("\n", 0, prev_end) + 1
        line = text[prev_start:prev_end]
        if line.lstrip().startswith(("//", "/*", "*")):
            if "invariant" in line.lower():
                return True
            cursor = prev_start
        else:
            break
    return False


def _swift_files(targets: list[str]) -> list[Path]:
    files: list[Path] = []
    for t in targets:
        p = Path(t)
        if p.is_dir():
            files.extend(sorted(p.rglob("*.swift")))
        elif p.suffix == ".swift":
            files.append(p)
    return files


def run(targets: list[str], strict: bool) -> int:
    missing = [t for t in targets if not Path(t).exists()]
    if missing:
        # A typo'd path must not pass green by scanning nothing.
        print(f"vibe-ios-doctor: path(s) not found: {', '.join(missing)}", file=sys.stderr)
        return 2
    files = _swift_files(targets)
    if not files:
        print("vibe-ios-doctor: no .swift files found", file=sys.stderr)
        return 0
    all_findings: list[Finding] = []
    for f in files:
        all_findings.extend(lint_text(str(f), f.read_text(encoding="utf-8")))

    fails = [x for x in all_findings if x.tier == 1]
    warns = [x for x in all_findings if x.tier == 2]
    for x in sorted(all_findings, key=lambda x: (x.path, x.line)):
        print(x.format())

    print(f"\nscanned {len(files)} file(s): {len(fails)} fail, {len(warns)} warn", file=sys.stderr)
    if fails:
        return 1
    if warns and strict:
        return 1
    return 0


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        prog="vibe-ios-doctor",
        description="Runnable gate for the AGENTS.md iOS posture. "
                    "Cannot catch: runtime CPU, off-screen Canvas redraws, or the "
                    "3-minute idle soak (AGENTS.md §1) — those remain your gate.")
    parser.add_argument("targets", nargs="+", help="Swift files or directories")
    parser.add_argument("--strict", action="store_true",
                        help="treat tier-2 warnings as failures (exit 1)")
    args = parser.parse_args(argv)
    return run(args.targets, args.strict)


if __name__ == "__main__":
    raise SystemExit(main())
