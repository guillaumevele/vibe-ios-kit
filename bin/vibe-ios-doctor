#!/usr/bin/env python3
"""vibe-ios-doctor — a runnable gate for the AGENTS.md iOS posture.

Point it at your Swift sources:

    vibe-ios-doctor Sources/

It enforces the rules a static check can enforce HONESTLY, in two tiers:

  tier 1 (FAIL, exit 1)   — unambiguous: emoji in code, `@unchecked Sendable`
                            without a stated invariant, formatter alloc in a body.
  tier 2 (WARN; FAIL with --strict) — needs a heuristic: an ungated
                            `TimelineView(.animation)` / `.repeatForever`.

It does NOT pretend to catch everything. The tier-2 rule is a token-PRESENCE
heuristic, not a proof of a gating relationship: it flags a continuous animation
when NO guard token and no Bool/Binding parameter is present in the enclosing
view. So it catches the *naive ungated* form, but a guard token that gates a
different view in the same type will suppress the warning (a possible false
negative). Runtime CPU, off-screen `Canvas` redraws, and the 3-minute idle soak
(AGENTS.md §1) are not statically decidable and remain your gate.

Zero dependencies (stdlib only).
"""
from __future__ import annotations

import argparse
import re
import sys
from pathlib import Path

# Emoji codepoint ranges chosen to EXCLUDE typographic punctuation the posture
# itself uses: em-dash U+2014, section sign U+00A7, arrows U+2190-21FF, curly
# quotes. So scanning the kit's own docs/code yields zero false positives.
_EMOJI_RANGES = [
    (0x1F300, 0x1FAFF),  # pictographs, emoticons, transport, extended-A
    (0x2600, 0x26FF),    # miscellaneous symbols
    (0x2700, 0x27BF),    # dingbats
    (0x1F1E6, 0x1F1FF),  # regional indicators (flags)
    (0xFE00, 0xFE0F),    # variation selectors (emoji presentation)
]
# A few emoji that live outside the ranges above (stars, squares) but are clearly
# not punctuation. Listed explicitly so we don't pull in the arrows next to them.
_EMOJI_SINGLES = frozenset({0x2B50, 0x2B55, 0x2B1B, 0x2B1C, 0x303D, 0x3030})

_GUARD_TOKENS = (
    "scenePhase", "isEnabled", "reduceMotion", "accessibilityReduceMotion",
    "onDisappear", "isAnimating", "isVisible", "isActive", "paused",
)
# Whole-word guard tokens (so `isActiveSubscription` does NOT match `isActive`),
# plus a parameter-gate signal: a view that takes a Bool/Binding is plausibly
# gated by its caller, so we do not flag its animations (avoids false positives
# on idiomatic decomposed/leaf views).
_GUARD_RE = re.compile(r"\b(" + "|".join(_GUARD_TOKENS) + r")\b")
_PARAM_GATE_RE = re.compile(r":\s*Bool\b|Binding\s*<")
# Triggers as regex so multi-line / reformatted calls are not silently missed.
_TRIGGERS = [
    ("TimelineView(.animation)", re.compile(r"TimelineView\s*\(\s*\.animation\b")),
    (".repeatForever(...)", re.compile(r"\.repeatForever\s*\(")),
]

# ── Visual-consistency detectors (AGENTS.md §6) ────────────────────────────────
# These keep an AI agent from drifting on colour/spacing/radius/buttons. The agent
# cannot SEE the rendered UI, so it must compose the DesignTokens single source of
# truth, never raw values. A token lint enforces USE OF THE SYSTEM — it does not
# (cannot) certify the system looks good; that needs a rendered/snapshot check.
#
# A type whose name marks it as the token source-of-truth is the ONE place raw
# colour components may live; everything matched inside it is whitelisted. The
# names are matched whole-word against the enclosing struct/class/enum/extension.
_TOKEN_TYPE_NAMES = ("DesignTokens", "DS", "Tokens", "Theme", "Palette",
                     "Color", "Colors", "Colour", "Space", "Spacing",
                     "Radius", "Radii", "Font", "Fonts", "Typography", "Motion")
_TOKEN_TYPE_RE = re.compile(
    r"\b(?:struct|class|enum|extension)\s+([A-Za-z_]\w*)")

# Raw colour from numeric components (FAIL): Color(red:…)/(hue:…), UIColor(red:…),
# CGColor(...). NOT Color("named")/(.systemFoo)/(white:) adaptive forms — those
# are catalog/system colours, which are fine. Hex via a 0x literal in a Color init
# is caught by the 0x clause.
_RAW_COLOR_RE = re.compile(
    r"\b(?:UI)?Color\s*\(\s*(?:red|hue)\s*:"   # Color(red: …) / Color(hue: …)
    r"|\b(?:UI)?Color\s*\(\s*0x")              # Color(0xRRGGBB …) hex literal
# An explicit '// design-token:' note also whitelists a raw component on that line
# (escape hatch for a one-off the author has consciously accepted).
_TOKEN_OK_RE = re.compile(r"design-?token", re.IGNORECASE)

# Ad-hoc CTA surface (FAIL): a `.background(<solid>)` immediately chained to
# `.cornerRadius(…)` is the hand-rolled-button look §6 bans (it drifts every time
# the agent re-derives it). The SANCTIONED forms — `.background(<material>, in:)`
# and `.background(<color>, in: <shape>)` — are NOT matched because they carry the
# shape inside `background`, so there is no trailing `.cornerRadius`.
_BG_RE = re.compile(r"\.background\s*\(")
_CORNER_AFTER_BG_RE = re.compile(r"\.cornerRadius\s*\(")
_MATERIAL_RE = re.compile(r"\.(?:ultraThin|thin|regular|thick|ultraThick)Material\b|Material\b")

# Magic numbers (WARN) where a token belongs: a NUMERIC literal as the argument to
# a spacing / radius / font-size site. A reference to the token namespace (`DS.`)
# anywhere in the same argument suppresses it. 0 and 1 are never flagged (hairline
# strokes, zero insets). Opacity/lineWidth are intentionally NOT covered — they
# are not part of the spacing/radius/type scale.
_NUM = r"-?\d+(?:\.\d+)?"
_MAGIC_SITES = [
    ("padding",      re.compile(r"\.padding\s*\(\s*(?:\.\w+\s*,\s*)?(" + _NUM + r")\s*\)")),
    ("spacing",      re.compile(r"\bspacing\s*:\s*(" + _NUM + r")\b")),
    ("cornerRadius", re.compile(r"\bcornerRadius\s*:\s*(" + _NUM + r")\b")),
    ("font size",    re.compile(r"\.system\s*\(\s*size\s*:\s*(" + _NUM + r")")),
]
_TOKEN_REF_RE = re.compile(r"\bDS\s*\.|\bDesignTokens\s*\.")


class Finding:
    def __init__(self, path, line, tier, message, section):
        self.path, self.line, self.tier = path, line, tier
        self.message, self.section = message, section

    def format(self) -> str:
        kind = "FAIL" if self.tier == 1 else "WARN"
        return f"{self.path}:{self.line}: [{kind}] {self.message} (AGENTS.md {self.section})"


def _lineno(text: str, idx: int) -> int:
    return text.count("\n", 0, idx) + 1


def _is_emoji(ch: str) -> bool:
    cp = ord(ch)
    return cp in _EMOJI_SINGLES or any(lo <= cp <= hi for lo, hi in _EMOJI_RANGES)


def _blank_noncode(text: str) -> str:
    """Replace the CONTENTS of // comments, /* */ comments, and "..." strings
    with spaces, preserving length and newlines (so offsets/line numbers stay
    valid). Guard/trigger scanning runs on this so a token in a comment or string
    can neither suppress a warning (false negative) nor trigger one."""
    out = list(text)
    i, n, state = 0, len(text), None
    while i < n:
        c = text[i]
        nxt = text[i + 1] if i + 1 < n else ""
        if state is None:
            if c == "/" and nxt == "/":
                state, out[i], out[i + 1] = "line", " ", " "
                i += 2; continue
            if c == "/" and nxt == "*":
                state, out[i], out[i + 1] = "block", " ", " "
                i += 2; continue
            if c == '"':
                state = "str"
            i += 1; continue
        if state == "line":
            if c == "\n":
                state = None
            else:
                out[i] = " "
        elif state == "block":
            if c == "*" and nxt == "/":
                state, out[i], out[i + 1] = None, " ", " "
                i += 2; continue
            if c != "\n":
                out[i] = " "
        elif state == "str":
            if c == "\\":
                i += 2; continue
            if c == '"':
                state = None
            elif c != "\n":
                out[i] = " "
        i += 1
    return "".join(out)


def _match_block(text: str, brace_idx: int) -> int:
    """Index of the `}` that closes the `{` at brace_idx."""
    depth = 0
    for i in range(brace_idx, len(text)):
        if text[i] == "{":
            depth += 1
        elif text[i] == "}":
            depth -= 1
            if depth == 0:
                return i
    return len(text)


def _match_paren(text: str, paren_idx: int) -> int:
    """Index of the `)` that closes the `(` at paren_idx (balanced)."""
    depth = 0
    for i in range(paren_idx, len(text)):
        if text[i] == "(":
            depth += 1
        elif text[i] == ")":
            depth -= 1
            if depth == 0:
                return i
    return len(text) - 1


def _enclosing_type_body(text: str, idx: int) -> str:
    """Body text of the innermost struct/class/extension/enum containing idx."""
    best = ""
    for kw in ("struct ", "class ", "extension ", "enum "):
        start = 0
        while True:
            k = text.find(kw, start)
            if k == -1 or k > idx:
                break
            brace = text.find("{", k)
            if brace == -1:
                break
            end = _match_block(text, brace)
            if brace < idx < end and (end - brace) < len(best or text) + 1:
                # keep the tightest enclosing block
                if not best or (end - brace) <= len(best):
                    best = text[brace:end]
            start = k + len(kw)
    return best


def _enclosing_type_names(text: str, idx: int) -> list[str]:
    """Names of every struct/class/enum/extension whose body contains idx.

    Used to whitelist raw colour components that live inside the design-token
    source-of-truth (e.g. `enum DS { enum Color { … } }`): if any enclosing type
    name is a token-type name, the site is the SANCTIONED home, not drift."""
    names: list[str] = []
    for m in _TOKEN_TYPE_RE.finditer(text):
        brace = text.find("{", m.end())
        if brace == -1 or brace > idx:
            continue
        end = _match_block(text, brace)
        if brace < idx < end:
            names.append(m.group(1))
    return names


def _in_token_type(text: str, idx: int) -> bool:
    return any(n in _TOKEN_TYPE_NAMES for n in _enclosing_type_names(text, idx))


def _check_raw_color(path, text, code, findings) -> None:
    """tier 1 — a colour built from raw numeric components (or a hex literal),
    OUTSIDE the design-token source-of-truth. Scans blanked code so a Color(red:)
    written in a comment/string does not count. Whitelisted inside a token type,
    or on a line carrying a '// design-token:' note (checked on the RAW line)."""
    for m in _RAW_COLOR_RE.finditer(code):
        if _in_token_type(code, m.start()):
            continue
        ln = _lineno(text, m.start())
        raw_line = text.split("\n")[ln - 1] if ln - 1 < text.count("\n") + 1 else ""
        if _TOKEN_OK_RE.search(raw_line):
            continue
        findings.append(Finding(path, ln, 1,
            "raw colour from components (Color(red:…)/hex) instead of a DS token "
            "— define it once in the token type", "§6"))


def _check_adhoc_cta(path, text, code, findings) -> None:
    """tier 1 — `.background(<solid>)` chained to a trailing `.cornerRadius(…)`:
    the hand-rolled button surface §6 bans. A brace/paren-balanced window from the
    end of `.background(...)` to the next `.cornerRadius(` keeps it local (so an
    unrelated later .cornerRadius on a different view is not falsely paired). The
    sanctioned `.background(<material/color>, in: <shape>)` form carries the shape
    INSIDE background, so it has no trailing .cornerRadius and never matches.
    A material background is whitelisted regardless."""
    for bg in _BG_RE.finditer(code):
        open_paren = code.find("(", bg.start())
        close = _match_paren(code, open_paren)
        inside = code[open_paren:close + 1]
        if _MATERIAL_RE.search(inside):
            continue  # material surface — fine
        # look only at the modifier chain immediately after background(...)
        window = code[close + 1: close + 60]
        cm = _CORNER_AFTER_BG_RE.search(window)
        if cm and "\n}" not in window[: cm.start()]:
            findings.append(Finding(path, _lineno(text, bg.start()), 1,
                "ad-hoc .background(...).cornerRadius(...) CTA — use the shared "
                "PrimaryButtonStyle (.buttonStyle(.dsPrimary)) or .background(_, in:)",
                "§6"))


def _is_test_file(code: str) -> bool:
    """XCTest scaffolding (snapshot harnesses, fixture tests) legitimately sizes
    fixtures with literal numbers (CGSize(390, 844), .padding(24) around a sample)
    — that is test chrome, not product-UI drift. The magic-number WARN is product
    UI only, so it is suppressed in test files. The raw-colour / ad-hoc-CTA FAILs
    still apply everywhere."""
    return ("XCTestCase" in code or "import XCTest" in code
            or re.search(r"\bfunc\s+test[A-Z_]", code) is not None)


def _check_magic_numbers(path, text, code, findings) -> None:
    """tier 2 — a numeric literal where a spacing/radius/font-size TOKEN belongs.
    Suppressed when the same argument references the token namespace (`DS.`), when
    the value is 0 or 1, inside the token-definition type itself (the scale's own
    numbers), or in an XCTest file (fixture chrome). Scans blanked code so a number
    in a comment/string never fires."""
    if _is_test_file(code):
        return
    for label, pattern in _MAGIC_SITES:
        for m in pattern.finditer(code):
            val = m.group(1)
            if val in ("0", "1", "0.0", "1.0"):
                continue
            # token reference anywhere on the matched line suppresses (e.g.
            # `cornerRadius: DS.Radius.lg` never matches the numeric pattern, but a
            # mixed line is covered defensively).
            ln = _lineno(text, m.start())
            line = code.split("\n")[ln - 1] if ln - 1 <= code.count("\n") else ""
            if _TOKEN_REF_RE.search(line):
                continue
            if _in_token_type(code, m.start()):
                continue
            findings.append(Finding(path, ln, 2,
                f"magic {label} value {val} — use a DS scale token "
                "(DS.Space / DS.Radius / DS.Font) so it stays consistent", "§6"))


def lint_text(path: str, text: str) -> list[Finding]:
    findings: list[Finding] = []
    code = _blank_noncode(text)  # comments/strings blanked; offsets preserved

    # tier 1 — emoji anywhere in the raw source (comments included).
    for i, ch in enumerate(text):
        if _is_emoji(ch):
            findings.append(Finding(path, _lineno(text, i), 1,
                                    f"emoji {ch!r} in source", "§6"))

    # tier 1 — @unchecked Sendable without a stated invariant (scan raw text so
    # the // invariant: note in a comment counts; walk back over the full
    # contiguous leading comment block, not a fixed 2-line window).
    pos = 0
    while True:
        k = text.find("@unchecked Sendable", pos)
        if k == -1:
            break
        if not _has_invariant_note(text, k):
            findings.append(Finding(path, _lineno(text, k), 1,
                                    "@unchecked Sendable without an // invariant: note", "§2"))
        pos = k + len("@unchecked Sendable")

    # tier 1 — formatter allocation inside a `var body` (on blanked code, so a
    # formatter named in a comment does not count).
    bpos = 0
    while True:
        b = code.find("var body", bpos)
        if b == -1:
            break
        brace = code.find("{", b)
        if brace == -1:
            break
        end = _match_block(code, brace)
        for formatter in ("DateFormatter(", "NumberFormatter("):
            j = code.find(formatter, brace, end)
            if j != -1:
                findings.append(Finding(path, _lineno(text, j), 1,
                                        f"{formatter}) allocated inside a body", "§3"))
        bpos = end

    # tier 2 — ungated continuous animation. A warning is suppressed when the
    # enclosing type carries a whole-word guard token OR takes a Bool/Binding
    # (parameter-gated). This is a token-PRESENCE heuristic, not a proof of a
    # gating relationship — see the module docstring's limitations.
    for label, pattern in _TRIGGERS:
        for m in pattern.finditer(code):
            scope = _enclosing_type_body(code, m.start()) or code
            if _GUARD_RE.search(scope) or _PARAM_GATE_RE.search(scope):
                continue
            findings.append(Finding(path, _lineno(text, m.start()), 2,
                                    f"ungated {label} — no visibility/active guard "
                                    "in the enclosing view", "§1"))

    # §6 visual consistency — keep an AI agent from drifting on the design system.
    # FAIL on the unambiguous drifts (raw colour, ad-hoc CTA surface); WARN on the
    # heuristic magic-number drift. All run on blanked code so a token written in a
    # comment/string can neither suppress nor trigger a finding.
    _check_raw_color(path, text, code, findings)
    _check_adhoc_cta(path, text, code, findings)
    _check_magic_numbers(path, text, code, findings)

    return findings


def _has_invariant_note(text: str, k: int) -> bool:
    """True if 'invariant' appears on the same line as index k or anywhere in the
    contiguous block of comment lines immediately above it."""
    line_end = text.find("\n", k)
    line_end = line_end if line_end != -1 else len(text)
    line_start = text.rfind("\n", 0, k) + 1
    if "invariant" in text[line_start:line_end].lower():
        return True
    # walk upward over contiguous comment lines
    cursor = line_start
    while cursor > 0:
        prev_end = cursor - 1
        prev_start = text.rfind("\n", 0, prev_end) + 1
        line = text[prev_start:prev_end]
        if line.lstrip().startswith(("//", "/*", "*")):
            if "invariant" in line.lower():
                return True
            cursor = prev_start
        else:
            break
    return False


def _swift_files(targets: list[str]) -> list[Path]:
    files: list[Path] = []
    for t in targets:
        p = Path(t)
        if p.is_dir():
            files.extend(sorted(p.rglob("*.swift")))
        elif p.suffix == ".swift":
            files.append(p)
    return files


def run(targets: list[str], strict: bool) -> int:
    missing = [t for t in targets if not Path(t).exists()]
    if missing:
        # A typo'd path must not pass green by scanning nothing.
        print(f"vibe-ios-doctor: path(s) not found: {', '.join(missing)}", file=sys.stderr)
        return 2
    files = _swift_files(targets)
    if not files:
        print("vibe-ios-doctor: no .swift files found", file=sys.stderr)
        return 0
    all_findings: list[Finding] = []
    for f in files:
        try:
            # Real codebases contain the odd non-UTF-8 file; never crash the whole
            # run over one — decode leniently and keep going.
            text = f.read_text(encoding="utf-8", errors="replace")
        except OSError as exc:
            print(f"vibe-ios-doctor: skipped {f}: {exc}", file=sys.stderr)
            continue
        all_findings.extend(lint_text(str(f), text))

    fails = [x for x in all_findings if x.tier == 1]
    warns = [x for x in all_findings if x.tier == 2]
    for x in sorted(all_findings, key=lambda x: (x.path, x.line)):
        print(x.format())

    print(f"\nscanned {len(files)} file(s): {len(fails)} fail, {len(warns)} warn", file=sys.stderr)
    if fails:
        return 1
    if warns and strict:
        return 1
    return 0


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        prog="vibe-ios-doctor",
        description="Runnable gate for the AGENTS.md iOS posture. "
                    "Cannot catch: runtime CPU, off-screen Canvas redraws, or the "
                    "3-minute idle soak (AGENTS.md §1) — those remain your gate.")
    parser.add_argument("targets", nargs="+", help="Swift files or directories")
    parser.add_argument("--strict", action="store_true",
                        help="treat tier-2 warnings as failures (exit 1)")
    args = parser.parse_args(argv)
    return run(args.targets, args.strict)


if __name__ == "__main__":
    raise SystemExit(main())
